# คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจาก Supabase Dashboard → Project Settings → API Keys
# (ต้องใส่ค่าเดียวกันใน Vercel → Settings → Environment Variables ด้วย)

# Project URL เช่น https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# anon / publishable key (ขึ้นต้น eyJ... หรือ sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role / secret key (ขึ้นต้น eyJ... หรือ sb_secret_...) — ใช้เฉพาะสคริปต์ย้ายข้อมูล ห้ามเปิดเผย
SUPABASE_SERVICE_ROLE_KEY=
